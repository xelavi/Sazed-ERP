<template>
  <div class="inventory-view">
    <!-- ── Page Header ─────────────────────────────── -->
    <header class="view-header">
      <div>
        <h1 class="view-title">Inventory</h1>
        <p class="view-subtitle">Stock overview, warehouses &amp; restocking</p>
      </div>
      <div class="header-actions">
        <button class="btn btn-secondary" @click="showMovements = !showMovements">
          <ArrowUpDown :size="16" />
          <span>Movements</span>
        </button>
        <button class="btn btn-secondary" @click="showRulesPanel = !showRulesPanel">
          <Settings :size="16" />
          <span>Reorder Rules</span>
        </button>
        <button class="btn btn-primary" @click="openRestockModal(null)">
          <PackagePlus :size="16" />
          <span>Restock</span>
        </button>
      </div>
    </header>

    <!-- ── Loading state ───────────────────────────── -->
    <div v-if="loading" class="loading-state">
      <div class="spinner"></div>
      <p>Loading inventory data...</p>
    </div>

    <!-- ── Main content ────────────────────────────── -->
    <div v-else class="inventory-content">
      <!-- KPI Row -->
      <section class="kpi-row">
        <div class="kpi-card">
          <div class="kpi-icon kpi-blue">
            <Package :size="22" />
          </div>
          <div class="kpi-info">
            <span class="kpi-value">{{ stats.total_products }}</span>
            <span class="kpi-label">Products</span>
          </div>
        </div>
        <div class="kpi-card">
          <div class="kpi-icon kpi-green">
            <Boxes :size="22" />
          </div>
          <div class="kpi-info">
            <span class="kpi-value">{{ formatNumber(stats.total_stock) }}</span>
            <span class="kpi-label">Total Units</span>
          </div>
        </div>
        <div class="kpi-card">
          <div class="kpi-icon kpi-amber">
            <AlertTriangle :size="22" />
          </div>
          <div class="kpi-info">
            <span class="kpi-value">{{ stats.low_stock_count }}</span>
            <span class="kpi-label">Low Stock</span>
          </div>
        </div>
        <div class="kpi-card">
          <div class="kpi-icon kpi-red">
            <PackageX :size="22" />
          </div>
          <div class="kpi-info">
            <span class="kpi-value">{{ stats.out_of_stock_count }}</span>
            <span class="kpi-label">Out of Stock</span>
          </div>
        </div>
        <div class="kpi-card">
          <div class="kpi-icon kpi-purple">
            <Euro :size="22" />
          </div>
          <div class="kpi-info">
            <span class="kpi-value">{{ formatCurrency(stats.total_value) }}</span>
            <span class="kpi-label">Inventory Value</span>
          </div>
        </div>
      </section>

      <!-- Two-column layout: Warehouses + Charts -->
      <div class="inventory-grid">
        <!-- ── Warehouses Panel ──────────────────── -->
        <section class="warehouses-panel">
          <h2 class="section-title">
            <Warehouse :size="20" />
            Warehouses
          </h2>
          <div class="warehouse-cards">
            <div
              v-for="wh in warehouses"
              :key="wh.id ?? 'unassigned'"
              class="warehouse-card"
              :class="{ active: selectedWarehouse === wh.id, 'has-alert': wh.low_stock > 0 }"
              @click="selectWarehouse(wh.id)"
            >
              <div class="wh-header">
                <div class="wh-name">
                  <div class="wh-avatar" :style="{ background: warehouseColor(wh.id) }">
                    {{ wh.name.charAt(0).toUpperCase() }}
                  </div>
                  <div>
                    <h3>{{ wh.name }}</h3>
                    <span class="wh-address">{{ wh.address || 'No address' }}</span>
                  </div>
                </div>
                <ChevronRight :size="16" class="wh-arrow" />
              </div>

              <div class="wh-stats">
                <div class="wh-stat">
                  <span class="wh-stat-val">{{ wh.product_count }}</span>
                  <span class="wh-stat-lbl">Products</span>
                </div>
                <div class="wh-stat">
                  <span class="wh-stat-val">{{ formatNumber(wh.total_stock) }}</span>
                  <span class="wh-stat-lbl">Units</span>
                </div>
                <div class="wh-stat">
                  <span class="wh-stat-val" :class="{ 'text-warning': wh.low_stock > 0 }">{{ wh.low_stock }}</span>
                  <span class="wh-stat-lbl">Low Stock</span>
                </div>
                <div class="wh-stat">
                  <span class="wh-stat-val">{{ formatCurrency(wh.value) }}</span>
                  <span class="wh-stat-lbl">Value</span>
                </div>
              </div>

              <!-- Capacity indicator bar -->
              <div class="wh-capacity">
                <div class="capacity-bar">
                  <div
                    class="capacity-fill"
                    :style="{ width: warehouseCapacityPct(wh) + '%' }"
                    :class="capacityClass(wh)"
                  ></div>
                </div>
                <span class="capacity-label">
                  {{ warehouseCapacityPct(wh) }}% capacity used
                </span>
              </div>
            </div>
          </div>
        </section>

        <!-- ── Right Column: Charts ──────────────── -->
        <div class="charts-column">
          <!-- Stock Distribution by Category -->
          <section class="chart-card">
            <h2 class="section-title">
              <BarChart3 :size="20" />
              Stock by Category
            </h2>
            <div class="bar-chart">
              <div
                v-for="cat in stockByCategory"
                :key="cat.category_name"
                class="bar-row"
              >
                <span class="bar-label">{{ cat.category_name }}</span>
                <div class="bar-track">
                  <div
                    class="bar-fill"
                    :style="{
                      width: categoryPct(cat.total_stock) + '%',
                      background: categoryColor(cat.category_name),
                    }"
                  ></div>
                </div>
                <span class="bar-value">{{ formatNumber(cat.total_stock) }}</span>
              </div>
            </div>
          </section>

          <!-- Movement Summary (last 30d) -->
          <section class="chart-card">
            <h2 class="section-title">
              <ArrowUpDown :size="20" />
              Movements (30 days)
            </h2>
            <div class="movement-rings">
              <div
                v-for="mv in movementSummary"
                :key="mv.movement_type"
                class="ring-stat"
              >
                <div class="ring" :class="'ring-' + mv.movement_type.toLowerCase()">
                  <svg viewBox="0 0 36 36" class="ring-svg">
                    <path
                      class="ring-bg"
                      d="M18 2.0845
                        a 15.9155 15.9155 0 0 1 0 31.831
                        a 15.9155 15.9155 0 0 1 0 -31.831"
                    />
                    <path
                      class="ring-fill"
                      :stroke-dasharray="ringPct(mv) + ', 100'"
                      d="M18 2.0845
                        a 15.9155 15.9155 0 0 1 0 31.831
                        a 15.9155 15.9155 0 0 1 0 -31.831"
                    />
                  </svg>
                  <span class="ring-number">{{ mv.count }}</span>
                </div>
                <span class="ring-label">{{ movementLabel(mv.movement_type) }}</span>
                <span class="ring-qty">{{ formatNumber(mv.total_qty) }} units</span>
              </div>
            </div>
          </section>
        </div>
      </div>

      <!-- ── Warehouse Stock Detail ──────────────── -->
      <section v-if="selectedWarehouse !== null" class="stock-detail">
        <div class="detail-header">
          <h2 class="section-title">
            <ClipboardList :size="20" />
            {{ selectedWarehouseName }} — Stock Detail
          </h2>
          <button class="btn btn-ghost" @click="selectedWarehouse = null">
            <X :size="16" /> Close
          </button>
        </div>

        <div v-if="warehouseProducts.length === 0" class="empty-detail">
          <PackageOpen :size="48" />
          <p>No products in this warehouse</p>
        </div>

        <div v-else class="product-grid">
          <div
            v-for="p in warehouseProducts"
            :key="p.id"
            class="product-stock-card"
            :class="'status-' + p.stock_status"
          >
            <div class="psc-top">
              <div class="psc-badge" :class="'badge-' + p.stock_status">
                {{ stockStatusLabel(p.stock_status) }}
              </div>
              <button
                class="psc-restock-btn"
                @click="openRestockModal(p)"
                title="Restock"
              >
                <PackagePlus :size="14" />
              </button>
            </div>
            <h4 class="psc-name">{{ p.name }}</h4>
            <span class="psc-sku">{{ p.sku }}</span>
            <div class="psc-stock-ring">
              <svg viewBox="0 0 36 36" class="stock-ring-svg">
                <path
                  class="ring-bg"
                  d="M18 2.0845
                    a 15.9155 15.9155 0 0 1 0 31.831
                    a 15.9155 15.9155 0 0 1 0 -31.831"
                />
                <path
                  class="ring-fill"
                  :class="'ring-' + p.stock_status"
                  :stroke-dasharray="productRingPct(p) + ', 100'"
                  d="M18 2.0845
                    a 15.9155 15.9155 0 0 1 0 31.831
                    a 15.9155 15.9155 0 0 1 0 -31.831"
                />
              </svg>
              <div class="stock-ring-center">
                <span class="stock-ring-val">{{ p.stock ?? 0 }}</span>
                <span class="stock-ring-lbl">units</span>
              </div>
            </div>
            <div class="psc-meta">
              <div class="psc-meta-item">
                <span>Min</span>
                <strong>{{ p.min_stock ?? '—' }}</strong>
              </div>
              <div class="psc-meta-item">
                <span>Reserved</span>
                <strong>{{ p.reserved ?? 0 }}</strong>
              </div>
              <div class="psc-meta-item">
                <span>Category</span>
                <strong>{{ p.category__name || '—' }}</strong>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ── Movements Drawer ────────────────────── -->
      <section v-if="showMovements" class="side-panel movements-panel">
        <div class="panel-header">
          <h2 class="section-title">
            <ArrowUpDown :size="20" />
            Recent Movements
          </h2>
          <button class="btn btn-ghost" @click="showMovements = false"><X :size="16" /></button>
        </div>
        <div class="movements-feed">
          <div v-for="m in movements" :key="m.id" class="movement-item">
            <div class="mv-icon" :class="'mv-' + m.movement_type.toLowerCase()">
              <ArrowDownToLine v-if="m.movement_type === 'In'" :size="14" />
              <ArrowUpFromLine v-else-if="m.movement_type === 'Out'" :size="14" />
              <RefreshCw v-else-if="m.movement_type === 'Adjust'" :size="14" />
              <CornerDownLeft v-else :size="14" />
            </div>
            <div class="mv-content">
              <span class="mv-product">{{ m.product_name }}</span>
              <span class="mv-detail">
                {{ m.movement_type }} · {{ m.quantity }} units
                <template v-if="m.document_ref"> · {{ m.document_ref }}</template>
              </span>
            </div>
            <span class="mv-time">{{ formatRelativeTime(m.created_at) }}</span>
          </div>
          <div v-if="movements.length === 0" class="empty-detail">
            <p>No recent movements</p>
          </div>
        </div>
      </section>

      <!-- ── Reorder Rules Panel ─────────────────── -->
      <section v-if="showRulesPanel" class="side-panel rules-panel">
        <div class="panel-header">
          <h2 class="section-title">
            <Settings :size="20" />
            Reorder Rules
          </h2>
          <button class="btn btn-ghost" @click="showRulesPanel = false"><X :size="16" /></button>
        </div>
        <div class="rules-list">
          <div
            v-for="rule in reorderRulesList"
            :key="rule.id"
            class="rule-card"
            :class="{ 'needs-reorder': rule.needs_reorder }"
          >
            <div class="rule-top">
              <div>
                <h4>{{ rule.product_name }}</h4>
                <span class="rule-sku">{{ rule.product_sku }} · {{ rule.warehouse_name }}</span>
              </div>
              <span class="rule-toggle" :class="{ active: rule.enabled }">
                {{ rule.enabled ? 'Active' : 'Off' }}
              </span>
            </div>
            <div class="rule-params">
              <div class="rule-param">
                <span>Current</span>
                <strong :class="{ 'text-warning': rule.needs_reorder }">{{ rule.product_stock ?? 0 }}</strong>
              </div>
              <div class="rule-param">
                <span>Min</span>
                <strong>{{ rule.min_stock }}</strong>
              </div>
              <div class="rule-param">
                <span>Reorder</span>
                <strong>+{{ rule.reorder_qty }}</strong>
              </div>
              <div class="rule-param">
                <span>Max</span>
                <strong>{{ rule.max_stock ?? '—' }}</strong>
              </div>
            </div>
            <button
              v-if="rule.needs_reorder"
              class="btn btn-primary btn-sm rule-restock-btn"
              @click="quickRestock(rule)"
            >
              <PackagePlus :size="14" />
              Restock {{ rule.reorder_qty }} units
            </button>
          </div>
          <div v-if="reorderRulesList.length === 0" class="empty-detail">
            <Settings :size="48" />
            <p>No reorder rules configured</p>
            <button class="btn btn-primary btn-sm" @click="showNewRuleForm = true">
              Create Rule
            </button>
          </div>
        </div>

        <!-- New Rule Form -->
        <div v-if="showNewRuleForm" class="new-rule-form">
          <h3>New Reorder Rule</h3>
          <div class="form-group">
            <label>Product</label>
            <select v-model="newRule.product_id" class="input">
              <option value="">Select product...</option>
              <option v-for="p in allProducts" :key="p.id" :value="p.id">{{ p.sku }} — {{ p.name }}</option>
            </select>
          </div>
          <div class="form-group">
            <label>Warehouse</label>
            <select v-model="newRule.warehouse_id" class="input">
              <option value="">Select warehouse...</option>
              <option v-for="wh in warehouses.filter(w => w.id)" :key="wh.id" :value="wh.id">{{ wh.name }}</option>
            </select>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Min Stock</label>
              <input v-model.number="newRule.min_stock" type="number" class="input" min="0" />
            </div>
            <div class="form-group">
              <label>Reorder Qty</label>
              <input v-model.number="newRule.reorder_qty" type="number" class="input" min="1" />
            </div>
            <div class="form-group">
              <label>Max Stock</label>
              <input v-model.number="newRule.max_stock" type="number" class="input" min="0" placeholder="Optional" />
            </div>
          </div>
          <div class="form-actions">
            <button class="btn btn-secondary btn-sm" @click="showNewRuleForm = false">Cancel</button>
            <button class="btn btn-primary btn-sm" @click="saveReorderRule" :disabled="!canSaveRule">Save Rule</button>
          </div>
        </div>
        <button v-if="!showNewRuleForm && reorderRulesList.length > 0" class="btn btn-secondary btn-sm add-rule-btn" @click="showNewRuleForm = true">
          <Plus :size="14" /> Add Rule
        </button>
      </section>
    </div>

    <!-- ── Restock Modal ─────────────────────────── -->
    <div v-if="restockModal" class="modal-overlay" @click.self="restockModal = false">
      <div class="modal-box">
        <div class="modal-header">
          <h2>Restock Product</h2>
          <button class="btn btn-ghost" @click="restockModal = false"><X :size="18" /></button>
        </div>
        <div class="modal-body">
          <div v-if="!restockData.product_id" class="form-group">
            <label>Product</label>
            <select v-model="restockData.product_id" class="input">
              <option value="">Select product...</option>
              <option v-for="p in allProducts" :key="p.id" :value="p.id">{{ p.sku }} — {{ p.name }} (stock: {{ p.stock ?? 0 }})</option>
            </select>
          </div>
          <div v-else class="restock-product-info">
            <Package :size="20" />
            <div>
              <strong>{{ restockData.product_name }}</strong>
              <span>Current stock: {{ restockData.current_stock ?? 0 }}</span>
            </div>
          </div>
          <div class="form-group">
            <label>Quantity to add</label>
            <input v-model.number="restockData.quantity" type="number" class="input" min="1" placeholder="e.g. 50" />
          </div>
          <div class="form-group">
            <label>Notes (optional)</label>
            <input v-model="restockData.notes" type="text" class="input" placeholder="e.g. Supplier delivery #1234" />
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-secondary" @click="restockModal = false">Cancel</button>
          <button class="btn btn-primary" @click="doRestock" :disabled="!restockData.product_id || !restockData.quantity || restockData.quantity <= 0">
            <PackagePlus :size="16" />
            Restock
          </button>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, onMounted } from 'vue'
import {
  Package, Boxes, AlertTriangle, PackageX, Euro,
  Warehouse, ChevronRight, BarChart3, ArrowUpDown,
  ClipboardList, X, PackagePlus, PackageOpen, Settings,
  ArrowDownToLine, ArrowUpFromLine, RefreshCw, CornerDownLeft,
  Plus,
} from 'lucide-vue-next'
import inventoryApi from '@/services/inventory'
import productsApi from '@/services/products'
import { useToast } from '@/composables/useToast'

const toast = useToast()

// ── State ──────────────────────────────────────────
const loading = ref(true)
const stats = ref({})
const warehouses = ref([])
const stockByCategory = ref([])
const movementSummary = ref([])
const selectedWarehouse = ref(null)
const warehouseProducts = ref([])
const showMovements = ref(false)
const movements = ref([])
const showRulesPanel = ref(false)
const reorderRulesList = ref([])
const showNewRuleForm = ref(false)
const restockModal = ref(false)
const allProducts = ref([])

const newRule = ref({ product_id: '', warehouse_id: '', min_stock: 10, reorder_qty: 25, max_stock: null })
const restockData = ref({ product_id: '', product_name: '', current_stock: 0, quantity: null, notes: '' })

// ── Computed ───────────────────────────────────────
const selectedWarehouseName = computed(() => {
  const wh = warehouses.value.find(w => w.id === selectedWarehouse.value)
  return wh ? wh.name : 'Warehouse'
})

const canSaveRule = computed(() =>
  newRule.value.product_id && newRule.value.warehouse_id
  && newRule.value.min_stock >= 0 && newRule.value.reorder_qty > 0
)

const maxCategoryStock = computed(() =>
  Math.max(...stockByCategory.value.map(c => c.total_stock), 1)
)

const totalMovements = computed(() =>
  Math.max(movementSummary.value.reduce((s, m) => s + m.count, 0), 1)
)

// ── Lifecycle ──────────────────────────────────────
onMounted(async () => {
  await loadOverview()
})

// ── Data loading ───────────────────────────────────
async function loadOverview() {
  loading.value = true
  try {
    const data = await inventoryApi.getOverview()
    stats.value = data.global_stats
    warehouses.value = data.warehouses
    stockByCategory.value = data.stock_by_category
    movementSummary.value = data.movement_summary
  } catch (e) {
    toast.error('Failed to load inventory data')
  } finally {
    loading.value = false
  }
}

async function selectWarehouse(id) {
  if (selectedWarehouse.value === id) {
    selectedWarehouse.value = null
    warehouseProducts.value = []
    return
  }
  selectedWarehouse.value = id
  try {
    warehouseProducts.value = await inventoryApi.getWarehouseStock(id ?? 0)
  } catch (e) {
    toast.error('Failed to load warehouse stock')
  }
}

async function loadMovements() {
  try {
    movements.value = await inventoryApi.getMovements(50)
  } catch (e) {
    toast.error('Failed to load movements')
  }
}

async function loadReorderRules() {
  try {
    reorderRulesList.value = await inventoryApi.getReorderRules()
  } catch (e) {
    toast.error('Failed to load reorder rules')
  }
}

async function loadAllProducts() {
  if (allProducts.value.length) return
  try {
    const res = await productsApi.getAll({ page_size: 500, status: 'Active', product_type: 'Product' })
    allProducts.value = res.results || res
  } catch (e) {
    console.error(e)
  }
}

// ── Watch panels ───────────────────────────────────
import { watch } from 'vue'

watch(showMovements, (v) => { if (v) loadMovements() })
watch(showRulesPanel, (v) => { if (v) { loadReorderRules(); loadAllProducts() } })
watch(restockModal, (v) => { if (v) loadAllProducts() })

// ── Actions ────────────────────────────────────────
function openRestockModal(product) {
  restockData.value = {
    product_id: product?.id || '',
    product_name: product?.name || '',
    current_stock: product?.stock ?? 0,
    quantity: null,
    notes: '',
  }
  restockModal.value = true
}

async function doRestock() {
  try {
    await inventoryApi.restockProduct({
      product_id: restockData.value.product_id,
      quantity: restockData.value.quantity,
      notes: restockData.value.notes,
    })
    toast.success(`Restocked ${restockData.value.quantity} units`)
    restockModal.value = false
    await loadOverview()
    if (selectedWarehouse.value !== null) {
      warehouseProducts.value = await inventoryApi.getWarehouseStock(selectedWarehouse.value ?? 0)
    }
  } catch (e) {
    toast.error('Restock failed')
  }
}

async function saveReorderRule() {
  try {
    await inventoryApi.createReorderRule(newRule.value)
    toast.success('Reorder rule saved')
    showNewRuleForm.value = false
    newRule.value = { product_id: '', warehouse_id: '', min_stock: 10, reorder_qty: 25, max_stock: null }
    await loadReorderRules()
  } catch (e) {
    toast.error('Failed to save rule')
  }
}

async function quickRestock(rule) {
  try {
    await inventoryApi.restockProduct({
      product_id: rule.product_id,
      quantity: rule.reorder_qty,
      notes: `Auto-restock via rule #${rule.id}`,
    })
    toast.success(`Restocked ${rule.reorder_qty} units of ${rule.product_name}`)
    await loadReorderRules()
    await loadOverview()
  } catch (e) {
    toast.error('Restock failed')
  }
}

// ── Helpers ────────────────────────────────────────
function formatNumber(n) {
  return (n ?? 0).toLocaleString('es-ES')
}

function formatCurrency(n) {
  return new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(n ?? 0)
}

const whColors = ['#667eea', '#10b981', '#f59e0b', '#8b5cf6', '#ec4899', '#ef4444', '#06b6d4']
function warehouseColor(id) {
  if (id === null) return '#94a3b8'
  return whColors[(id - 1) % whColors.length]
}

function warehouseCapacityPct(wh) {
  const total = stats.value.total_stock || 1
  return Math.min(Math.round((wh.total_stock / total) * 100), 100)
}

function capacityClass(wh) {
  const pct = warehouseCapacityPct(wh)
  if (pct >= 80) return 'cap-high'
  if (pct >= 50) return 'cap-med'
  return 'cap-low'
}

function categoryPct(stock) {
  return Math.round((stock / maxCategoryStock.value) * 100)
}

const catColors = ['#667eea', '#10b981', '#f59e0b', '#8b5cf6', '#ec4899', '#ef4444', '#06b6d4', '#84cc16']
function categoryColor(name) {
  let hash = 0
  for (const ch of name) hash = ch.charCodeAt(0) + ((hash << 5) - hash)
  return catColors[Math.abs(hash) % catColors.length]
}

function ringPct(mv) {
  return Math.round((mv.count / totalMovements.value) * 100)
}

function movementLabel(type) {
  return { In: 'Entries', Out: 'Exits', Adjust: 'Adjustments', Return: 'Returns' }[type] || type
}

function stockStatusLabel(s) {
  return { ok: 'OK', low: 'Low', out_of_stock: 'Out' }[s] || s
}

function productRingPct(p) {
  const max = p.min_stock ? p.min_stock * 3 : 100
  return Math.min(Math.round(((p.stock ?? 0) / max) * 100), 100)
}

function formatRelativeTime(iso) {
  const diff = Date.now() - new Date(iso).getTime()
  const mins = Math.floor(diff / 60000)
  if (mins < 1) return 'just now'
  if (mins < 60) return `${mins}m ago`
  const hours = Math.floor(mins / 60)
  if (hours < 24) return `${hours}h ago`
  const days = Math.floor(hours / 24)
  return `${days}d ago`
}
</script>

